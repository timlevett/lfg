{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["./plugins/lfg-bridge.js"],
  "commands": {
    "lfg-status": {
      "description": "Check lfg connection status",
      "prompt": "Check if the lfg LED panel is responding by running: curl -s http://localhost:6969/status || echo 'lfg not running'"
    }
  }
}
